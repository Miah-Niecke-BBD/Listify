CREATE PROCEDURE UpdateTaskDependency
    @taskID INT,
    @dependentTaskID INT
AS
BEGIN
    BEGIN TRANSACTION

    BEGIN TRY
        DELETE FROM TaskDependencies WHERE taskID = @taskID AND dependentTaskID = @dependentTaskID;

        INSERT INTO TaskDependencies (taskID, dependentTaskID)
        VALUES (@taskID, @dependentTaskID);

IF @@ROWCOUNT = 0
BEGIN
    THROW 50000, 'Task ID does not exist', 1;
END

        COMMIT;
    END TRY
    BEGIN CATCH
        ROLLBACK;
        THROW;
    END CATCH
END;
GO
